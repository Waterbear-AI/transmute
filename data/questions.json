  "scenarios": [
    {
      "id": "sc_belong_01",
      "type": "scenario",
      "dimension": "Transmutation Capacity",
      "sub_dimension": "Deprivation Filtering",
      "maslow_level": "belonging",
      "narrative": "Your coworker is struggling with their workload and comes to you visibly stressed. They start venting about how overwhelmed they feel and how unfair the situation is.",
      "choices": [
        {
          "key": "a",
          "text": "Listen deeply and help them process what they're feeling, offering calm presence",
          "quadrant_weight": {"transmuter": 1.0}
        },
        {
          "key": "b",
          "text": "Take on their stress as your own — you can't help but feel overwhelmed too",
          "quadrant_weight": {"absorber": 1.0}
        },
        {
          "key": "c",
          "text": "Acknowledge their frustration briefly and suggest they talk to their manager",
          "quadrant_weight": {"conduit": 1.0}
        },
        {
          "key": "d",
          "text": "Feel a sense of relief or satisfaction that it's their problem, not yours",
          "quadrant_weight": {"extractor": 1.0}
        }
      ],
      "follow_up_prompt": "Can you think of a specific time this happened? What did you actually do?",
      "order": 1,
      "tags": ["interpersonal", "belonging"],
      "source": "transmutarianism-v13-s4"
    },
    {
      "id": "sc_esteem_01",
      "type": "scenario",
      "dimension": "Transmutation Capacity",
      "sub_dimension": "Fulfillment Emission",
      "maslow_level": "esteem",
      "narrative": "You receive unexpected recognition at work for a project you led. Your team contributed significantly, but you're the one being praised publicly.",
      "choices": [
        {
          "key": "a",
          "text": "Immediately redirect credit to the team and amplify their contributions publicly",
          "quadrant_weight": {"transmuter": 1.0}
        },
        {
          "key": "b",
          "text": "Accept the praise and amplify it — talk about the achievement enthusiastically",
          "quadrant_weight": {"magnifier": 1.0}
        },
        {
          "key": "c",
          "text": "Accept it graciously but don't make a big deal about it either way",
          "quadrant_weight": {"conduit": 1.0}
        },
        {
          "key": "d",
          "text": "Enjoy the recognition privately and hold onto that good feeling for yourself",
          "quadrant_weight": {"absorber": 1.0}
        }
      ],
      "follow_up_prompt": "How did that feel? Did you share it with anyone afterward?",
      "order": 2,
      "tags": ["professional", "esteem"],
      "source": "transmutarianism-v13-s4"
    },
    {
      "id": "sc_safety_01",
      "type": "scenario",
      "dimension": "Transmutation Capacity",
      "sub_dimension": "Deprivation Filtering",
      "maslow_level": "safety",
      "narrative": "You're having a difficult day — a series of small frustrations have been building up. You come home and your partner or roommate cheerfully asks you about your day.",
      "choices": [
        {
          "key": "a",
          "text": "Take a breath, acknowledge your bad day honestly but without dumping the frustration on them",
          "quadrant_weight": {"transmuter": 1.0}
        },
        {
          "key": "b",
          "text": "Vent about everything that went wrong, amplifying each frustration as you retell it",
          "quadrant_weight": {"magnifier": 1.0}
        },
        {
          "key": "c",
          "text": "Say 'fine' and keep the frustration to yourself",
          "quadrant_weight": {"conduit": 1.0}
        },
        {
          "key": "d",
          "text": "Snap at them — their cheerfulness feels tone-deaf given your day",
          "quadrant_weight": {"extractor": 1.0}
        }
      ],
      "follow_up_prompt": "What usually happens when you bring stress home? How does it affect the people around you?",
      "order": 3,
      "tags": ["personal", "safety"],
      "source": "transmutarianism-v13-s4"
    },
    {
      "id": "sc_selfact_01",
      "type": "scenario",
      "dimension": "Transmutation Capacity",
      "sub_dimension": "Amplification Awareness",
      "maslow_level": "self-actualization",
      "narrative": "A friend shares a creative project they've been working on. It's clearly meaningful to them, though you can see areas where it could be improved.",
      "choices": [
        {
          "key": "a",
          "text": "Appreciate what's working, then offer thoughtful feedback that helps them grow",
          "quadrant_weight": {"transmuter": 1.0}
        },
        {
          "key": "b",
          "text": "Get genuinely excited about it and share it with others to amplify their work",
          "quadrant_weight": {"magnifier": 1.0}
        },
        {
          "key": "c",
          "text": "Say it looks nice and move on to another topic",
          "quadrant_weight": {"conduit": 1.0}
        },
        {
          "key": "d",
          "text": "Point out the flaws — they need honest feedback, and sugarcoating doesn't help",
          "quadrant_weight": {"extractor": 1.0}
        }
      ],
      "follow_up_prompt": "How do you typically respond when someone shares something they're proud of?",
